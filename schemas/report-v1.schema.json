{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/aditya/codebase-analysis/schemas/report-v1.schema.json",
  "title": "Codebase Analysis Report v1",
  "description": "JSON output schema for the Codebase Analyzer CLI tool. Breaking changes require a version bump.",
  "type": "object",
  "required": ["meta", "sizing", "structure", "repoHealth", "complexity", "testAnalysis", "git", "dependencies", "security", "techStack", "envVars", "duplication", "architecture"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "description": "Report metadata",
      "required": ["generatedAt", "analyzerVersion", "directory", "analysisCompleteness"],
      "additionalProperties": false,
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of report generation"
        },
        "analyzerVersion": {
          "type": "string",
          "description": "Semantic version of the analyzer (e.g., \"1.0.0\")"
        },
        "directory": {
          "type": "string",
          "description": "Absolute path to the analyzed repository"
        },
        "analysisCompleteness": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of analysis modules that completed successfully (0-100)"
        },
        "grade": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "F", "INCOMPLETE"],
          "description": "Overall letter grade. INCOMPLETE if analysisCompleteness < 60%."
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Weighted score based on rubric.yaml"
        },
        "durationMs": {
          "type": "number",
          "description": "Total wall-clock milliseconds for the full analysis"
        }
      }
    },

    "sizing": {
      "type": "object",
      "description": "File and line count metrics",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "totalFiles": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of tracked, non-binary files"
        },
        "totalLines": {
          "type": "integer",
          "minimum": 0,
          "description": "Sum of all lines across all files (including blank/comment)"
        },
        "totalCodeLines": {
          "type": "integer",
          "minimum": 0,
          "description": "Lines excluding blank and comment lines"
        },
        "totalCommentLines": {
          "type": "integer",
          "minimum": 0,
          "description": "Comment-only lines"
        },
        "totalBlankLines": {
          "type": "integer",
          "minimum": 0,
          "description": "Blank lines"
        },
        "languages": {
          "type": "array",
          "description": "Per-language breakdown, ordered by codeLines descending",
          "items": {
            "type": "object",
            "required": ["language"],
            "additionalProperties": false,
            "properties": {
              "language": {
                "type": "string",
                "description": "Canonical language name (e.g., \"TypeScript\")"
              },
              "extension": {
                "type": "string",
                "description": "Primary file extension (e.g., \".ts\")"
              },
              "files": {
                "type": "integer",
                "minimum": 0,
                "description": "Number of files of this language"
              },
              "lines": {
                "type": "integer",
                "minimum": 0,
                "description": "Total lines in files of this language"
              },
              "codeLines": {
                "type": "integer",
                "minimum": 0
              },
              "blankLines": {
                "type": "integer",
                "minimum": 0
              },
              "commentLines": {
                "type": "integer",
                "minimum": 0
              },
              "percentOfCode": {
                "type": "number",
                "minimum": 0,
                "maximum": 100,
                "description": "Percentage of total code lines"
              }
            }
          }
        },
        "godFiles": {
          "type": "array",
          "description": "Files exceeding 500 LOC threshold",
          "items": {
            "type": "object",
            "required": ["path", "lines", "language"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "description": "Relative path from repo root"
              },
              "lines": {
                "type": "integer",
                "minimum": 1,
                "description": "Total lines in the file"
              },
              "language": {
                "type": "string"
              }
            }
          }
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "structure": {
      "type": "object",
      "description": "Directory structure metrics",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "treeString": {
          "type": "string",
          "description": "Human-readable indented directory tree"
        },
        "tree": {
          "$ref": "#/definitions/folderNode",
          "description": "Recursive folder/file tree as structured data"
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "repoHealth": {
      "type": "object",
      "description": "Repository health checks",
      "required": ["checks", "meta"],
      "additionalProperties": false,
      "properties": {
        "checks": {
          "type": "array",
          "description": "Array of health check results",
          "items": {
            "type": "object",
            "required": ["id", "name", "present"],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable machine identifier for scoring (e.g. 'readme', 'license', 'ci')"
              },
              "name": {
                "type": "string",
                "description": "Human-readable display name for reports"
              },
              "present": {
                "type": "boolean",
                "description": "Whether the check passed"
              },
              "path": {
                "type": "string",
                "description": "Relative path of matched file (only when present is true)"
              },
              "note": {
                "type": "string",
                "description": "Optional human-readable annotation"
              }
            }
          }
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "complexity": {
      "type": "object",
      "description": "McCabe cyclomatic complexity metrics",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "repoAvgComplexity": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Mean complexity across all functions. Null if no functions found."
        },
        "repoMaxComplexity": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Highest complexity of any single function. Null if no functions found."
        },
        "totalFunctions": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of functions/methods analyzed"
        },
        "fileComplexities": {
          "type": "array",
          "description": "Per-file complexity summaries",
          "items": {
            "type": "object",
            "required": ["file", "avgComplexity", "maxComplexity", "functionCount"],
            "additionalProperties": false,
            "properties": {
              "file": {
                "type": "string",
                "description": "Relative path from repo root"
              },
              "avgComplexity": {
                "type": "number",
                "minimum": 0
              },
              "maxComplexity": {
                "type": "integer",
                "minimum": 0
              },
              "functionCount": {
                "type": "integer",
                "minimum": 0
              },
              "functions": {
                "type": "array",
                "items": { "$ref": "#/definitions/functionComplexity" }
              }
            }
          }
        },
        "hotspots": {
          "type": "array",
          "description": "Top 10 most complex functions",
          "maxItems": 10,
          "items": { "$ref": "#/definitions/functionComplexity" }
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "testAnalysis": {
      "type": "object",
      "description": "Test coverage and framework detection",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "testFiles": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of detected test files"
        },
        "testLines": {
          "type": "integer",
          "minimum": 0,
          "description": "Total lines in test files"
        },
        "codeLines": {
          "type": "integer",
          "minimum": 0,
          "description": "Total code lines in non-test files"
        },
        "testCodeRatio": {
          "type": "number",
          "minimum": 0,
          "description": "testLines / codeLines * 100"
        },
        "testFrameworks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of detected test framework names"
        },
        "coverageConfigFound": {
          "type": "boolean",
          "description": "Whether coverage configuration was detected"
        },
        "testFileList": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "lines"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "description": "Relative path of test file"
              },
              "lines": {
                "type": "integer",
                "minimum": 0,
                "description": "Number of lines in the test file"
              }
            }
          },
          "description": "Detected test files with line counts"
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "duplication": {
      "type": "object",
      "description": "Code duplication metrics from jscpd",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "duplicateLines": {
          "type": "integer",
          "minimum": 0
        },
        "duplicatePercentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "totalClones": {
          "type": "integer",
          "minimum": 0
        },
        "clones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["firstFile", "secondFile", "lines"],
            "additionalProperties": false,
            "properties": {
              "firstFile": { "type": "string" },
              "firstStartLine": { "type": "integer" },
              "firstEndLine": { "type": "integer" },
              "secondFile": { "type": "string" },
              "secondStartLine": { "type": "integer" },
              "secondEndLine": { "type": "integer" },
              "lines": { "type": "integer", "minimum": 1 },
              "tokens": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "security": {
      "type": "object",
      "description": "Secret detection metrics from gitleaks",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "secretsFound": {
          "type": "integer",
          "minimum": 0
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file", "line", "ruleId"],
            "properties": {
              "file": {
                "type": "string",
                "description": "Relative path"
              },
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "ruleId": {
                "type": "string",
                "description": "Gitleaks rule identifier"
              },
              "description": {
                "type": "string",
                "description": "Human-readable description of the finding"
              }
            },
            "additionalProperties": false
          },
          "description": "Secret findings. NEVER contains raw secret values."
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "git": {
      "type": "object",
      "description": "Git history metrics",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "totalCommits": {
          "type": "integer",
          "minimum": 0
        },
        "contributors": {
          "type": "integer",
          "minimum": 0
        },
        "firstCommitDate": {
          "type": ["string", "null"]
        },
        "lastCommitDate": {
          "type": ["string", "null"]
        },
        "activeDays": {
          "type": "integer",
          "minimum": 0
        },
        "topContributors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "email", "commits"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string" },
              "commits": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "conventionalCommitPercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of commits following conventional commit format"
        },
        "busFactor": {
          "type": "integer",
          "minimum": 0,
          "description": "Minimum number of contributors covering 50% of commits"
        },
        "commitFrequency": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "commitsPerWeek": { "type": "number", "minimum": 0 },
            "commitsPerMonth": { "type": "number", "minimum": 0 }
          }
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "dependencies": {
      "type": "object",
      "description": "Dependency analysis metrics",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "totalDependencies": {
          "type": "integer",
          "minimum": 0
        },
        "directDependencies": {
          "type": "integer",
          "minimum": 0
        },
        "devDependencies": {
          "type": "integer",
          "minimum": 0
        },
        "ecosystems": {
          "type": "array",
          "items": { "type": "string" }
        },
        "packageManager": {
          "type": ["string", "null"]
        },
        "dependencies": {
          "type": "array",
          "description": "List of all detected dependencies",
          "items": {
            "type": "object",
            "required": ["name", "version", "type", "ecosystem"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["direct", "dev", "peer", "optional"]
              },
              "ecosystem": { "type": "string" }
            }
          }
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "techStack": {
      "type": "object",
      "description": "Detected technology stack",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "stack": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "category", "source"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "category": {
                "type": "string",
                "enum": ["framework", "build-tool", "linter", "formatter", "test-runner", "deployment", "database", "service", "language-tool", "other"]
              },
              "source": {
                "type": "string",
                "description": "How this tool was detected (e.g., package.json, file presence)"
              }
            }
          }
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "envVars": {
      "type": "object",
      "description": "Environment variable detection",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "totalVars": {
          "type": "integer",
          "minimum": 0
        },
        "variables": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "file", "line"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "file": { "type": "string" },
              "line": { "type": "integer", "minimum": 1 },
              "prefix": { "type": "string" }
            }
          }
        },
        "byPrefix": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "description": "Count of variables grouped by prefix"
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "architecture": {
      "type": "object",
      "description": "Import graph and module architecture metrics",
      "required": ["meta"],
      "additionalProperties": false,
      "properties": {
        "totalImports": {
          "type": "integer",
          "minimum": 0
        },
        "uniqueModules": {
          "type": "integer",
          "minimum": 0
        },
        "importGraph": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "additionalProperties": false,
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        },
        "circularDependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cycle"],
            "additionalProperties": false,
            "properties": {
              "cycle": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 2
              }
            }
          }
        },
        "moduleCohesion": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["module", "intraImports", "totalImports", "cohesionRatio"],
            "additionalProperties": false,
            "properties": {
              "module": { "type": "string" },
              "intraImports": { "type": "integer", "minimum": 0 },
              "totalImports": { "type": "integer", "minimum": 0 },
              "cohesionRatio": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "meta": { "$ref": "#/definitions/analyzerMeta" }
      }
    },

    "scoring": {
      "type": "object",
      "description": "Scoring breakdown by category",
      "additionalProperties": false,
      "properties": {
        "totalScore": {
          "type": "number",
          "minimum": 0
        },
        "totalPossible": {
          "type": "number",
          "minimum": 0,
          "description": "Sum of weights for computed (non-skipped) categories"
        },
        "normalizedScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "totalScore / totalPossible * 100, normalized for partial data"
        },
        "grade": {
          "type": "string",
          "enum": ["A", "B", "C", "D", "F", "INCOMPLETE"],
          "description": "Overall letter grade"
        },
        "categories": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "score": { "type": "number", "minimum": 0 },
              "maxScore": { "type": "number", "minimum": 0 },
              "metrics": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "score": { "type": "number", "minimum": 0 },
                    "maxScore": { "type": "number", "minimum": 0 },
                    "label": { "type": "string" },
                    "value": {}
                  }
                }
              }
            }
          }
        }
      }
    }
  },

  "definitions": {
    "analyzerMeta": {
      "type": "object",
      "description": "Metadata for each analyzer section",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["computed", "skipped", "error"],
          "description": "Whether this section was computed, skipped, or errored"
        },
        "reason": {
          "type": ["string", "null"],
          "description": "Explanation for skipped/error status. Null when computed."
        },
        "durationMs": {
          "type": "number",
          "minimum": 0,
          "description": "Wall-clock milliseconds for this analysis pass"
        }
      }
    },

    "functionComplexity": {
      "type": "object",
      "description": "Complexity data for a single function",
      "required": ["name", "file", "line", "complexity"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Function name, <anonymous>, or <arrow>"
        },
        "file": {
          "type": "string",
          "description": "Relative path from repo root"
        },
        "line": {
          "type": "integer",
          "minimum": 1,
          "description": "Starting line number (1-indexed)"
        },
        "complexity": {
          "type": "integer",
          "minimum": 1,
          "description": "McCabe cyclomatic complexity score"
        }
      }
    },

    "folderNode": {
      "type": "object",
      "description": "Recursive directory tree node",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Directory or file name"
        },
        "fileCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of direct child files"
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/folderNode" },
          "description": "Child nodes"
        }
      }
    }
  }
}
